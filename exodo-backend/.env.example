# ═══════════════════════════════════════════════════════════════════
# ÉXODO BY BEHAVIOR — Configuración del Backend
# Copiar a .env y rellenar con valores reales.
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# Servidor / Red
# ─────────────────────────────────────────────────────────────────
# HOST donde escucha el backend. Default 0.0.0.0 (todas las interfaces).
# Si quieres exponerlo solo en localhost, pon 127.0.0.1.
BACKEND_HOST=0.0.0.0

# Puerto del backend. Default 3000.
PORT=3000

# Entorno: development | production
NODE_ENV=development

# CORS: dominios permitidos separados por coma. Vacío = cualquiera (dev).
# Ejemplo producción: CORS_ORIGIN=https://exodo.app,https://admin.exodo.app
CORS_ORIGIN=

# ─────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─────────────────────────────────────────────────────────────────
# API keys de providers de IA
# ─────────────────────────────────────────────────────────────────

# Gemini (clasificador de intención + fallback documental)
GOOGLE_AI_API_KEY=AIza...

# Anthropic Claude (sintaxis / razonamiento profundo)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (DeepSeek, Llama, etc.)
OPENROUTER_API_KEY=sk-or-...

# Groq (inferencia rápida)
GROQ_API_KEY=gsk_...

# ─────────────────────────────────────────────────────────────────
# NVIDIA NIM — Cascade Éxodo
# Cada modelo tiene su propia API key (política de NIM).
# Si dejas vacío NIM_KEY_<MODELO>, se usa el defaultKey hardcoded
# (solo válido para desarrollo; en producción TODAS deben venir de env).
# ─────────────────────────────────────────────────────────────────
NIM_KEY_NEMOTRON=
NIM_KEY_DEEPSEEK_FLASH=
NIM_KEY_DEEPSEEK_PRO=
NIM_KEY_MINIMAX_M3=
NIM_KEY_KIMI=
NIM_KEY_GLM=
NIM_KEY_MINIMAX_M2_7=
NIM_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Storage y modelos locales
# ─────────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=exodo-files
CLOUDFLARE_R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com

OLLAMA_LOCAL_URL=http://localhost:11434